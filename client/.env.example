# Used when the UI is built as a static site (e.g. Render Static).
# Set in the host’s env at build time. No trailing slash.
# VITE_API_BASE=https://websockets-api.onrender.com
#
# Optional override if the WebSocket URL is not derived from VITE_API_BASE:
# VITE_WS_URL=wss://websockets-api.onrender.com/ws
